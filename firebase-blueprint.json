{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user profile in the Kilvish Empire.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The user's unique ID." },
        "email": { "type": "string", "description": "The user's email address." },
        "displayName": { "type": "string", "description": "The user's display name." },
        "photoURL": { "type": "string", "description": "The user's photo URL." },
        "role": { "type": "string", "enum": ["citizen", "warrior", "admin"], "description": "The user's role." },
        "createdAt": { "type": "timestamp", "description": "When the user joined." }
      },
      "required": ["uid", "email", "role", "createdAt"]
    },
    "SavedContent": {
      "title": "Saved Content",
      "description": "Content generated and saved by the user.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique ID of the content." },
        "userId": { "type": "string", "description": "The ID of the user who created this." },
        "type": { "type": "string", "enum": ["song", "report", "chat", "arrangement", "script", "image", "transcript", "intelligence", "music", "feedback", "brand_identity"], "description": "The type of content." },
        "title": { "type": "string", "description": "Title or prompt of the content." },
        "content": { "type": "string", "description": "The actual content (JSON stringified data)." },
        "tags": { "type": "array", "items": { "type": "string" }, "description": "Tags for the content." },
        "timestamp": { "type": "string", "description": "When the content was saved (ISO string)." }
      },
      "required": ["id", "userId", "type", "title", "content", "timestamp"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles."
    },
    "users/{userId}/saved_content/{contentId}": {
      "schema": { "$ref": "#/entities/SavedContent" },
      "description": "Content saved by the user."
    }
  }
}
